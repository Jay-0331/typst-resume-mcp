{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Resume YAML Schema",
  "description": "Schema for the Typst resume template YAML data file",
  "type": "object",
  "required": ["personal"],
  "additionalProperties": false,
  "properties": {
    "personal": {
      "type": "object",
      "required": ["name", "email"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Full name"
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "phone": {
          "type": ["string", "null"]
        },
        "url": {
          "type": ["string", "null"],
          "format": "uri",
          "description": "Portfolio or personal website URL"
        },
        "titles": {
          "type": "array",
          "description": "Taglines displayed in the header (e.g. role, tech stack, domain)",
          "items": { "type": "string" },
          "minItems": 1
        },
        "location": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "city": { "type": "string" },
            "region": { "type": "string" }
          }
        },
        "profiles": {
          "type": "array",
          "description": "Social/professional profile links (LinkedIn, GitHub, etc.)",
          "items": {
            "type": "object",
            "required": ["network", "url"],
            "additionalProperties": false,
            "properties": {
              "network": {
                "type": "string",
                "description": "Platform name, e.g. LinkedIn, GitHub"
              },
              "username": {
                "type": "string",
                "description": "Handle or username on the platform"
              },
              "url": {
                "type": "string",
                "format": "uri"
              }
            }
          }
        }
      }
    },

    "summary": {
      "type": ["string", "null"],
      "description": "1-2 sentence professional summary. Tailor to target role."
    },

    "education": {
      "type": ["array", "null"],
      "items": {
        "type": "object",
        "required": ["institution", "studyType", "area", "startDate", "endDate", "location"],
        "additionalProperties": false,
        "properties": {
          "institution": { "type": "string" },
          "studyType": {
            "type": "string",
            "description": "Degree type, e.g. M.S, B.E, Bachelor of Science"
          },
          "area": {
            "type": "string",
            "description": "Field of study, e.g. Software Engineering Systems"
          },
          "gpa": {
            "type": ["string", "null"],
            "description": "GPA string, e.g. '3.83 / 4.0'"
          },
          "startDate": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
            "description": "ISO date YYYY-MM-DD"
          },
          "endDate": {
            "type": "string",
            "pattern": "^(\\d{4}-\\d{2}-\\d{2}|present)$",
            "description": "ISO date YYYY-MM-DD or 'present'"
          },
          "location": {
            "type": "string",
            "description": "Display string, e.g. 'Boston, MA'"
          }
        }
      }
    },

    "work": {
      "type": ["array", "null"],
      "items": {
        "type": "object",
        "required": ["organization", "location", "positions"],
        "additionalProperties": false,
        "properties": {
          "organization": { "type": "string" },
          "location": {
            "type": "string",
            "description": "Display string, e.g. 'Waltham, MA'"
          },
          "positions": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["position", "startDate", "endDate", "highlights"],
              "additionalProperties": false,
              "properties": {
                "position": {
                  "type": "string",
                  "description": "Job title, e.g. Software Engineering Intern"
                },
                "startDate": {
                  "type": "string",
                  "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
                },
                "endDate": {
                  "type": "string",
                  "pattern": "^(\\d{4}-\\d{2}-\\d{2}|present)$"
                },
                "highlights": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "string",
                    "description": "Use *text* for bold Typst markup. Wrap in double quotes if special characters present."
                  }
                }
              }
            }
          }
        }
      }
    },

    "projects": {
      "type": ["array", "null"],
      "description": "Projects have NO date fields. techstack renders as subtitle.",
      "items": {
        "type": "object",
        "required": ["name", "highlights"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "url": {
            "type": ["string", "null"],
            "format": "uri"
          },
          "techstack": {
            "type": ["string", "null"],
            "description": "Comma-separated tech list, e.g. 'Go, Kubernetes, AWS, Kafka'"
          },
          "highlights": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          }
        }
      }
    },

    "skills": {
      "type": ["array", "null"],
      "items": {
        "type": "object",
        "required": ["category", "skills"],
        "additionalProperties": false,
        "properties": {
          "category": {
            "type": "string",
            "description": "Skill group label, e.g. 'Programming Languages', 'Frameworks', 'Databases & Cloud'"
          },
          "skills": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
